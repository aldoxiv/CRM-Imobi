rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidLead(data) {
      // Must have core fields
      let coreKeys = ['score', 'status', 'createdAt', 'updatedAt', 'chatHistory', 'qualifications'];
      return data.keys().hasAll(coreKeys)
        && data.score is int && data.score >= 0 && data.score <= 100
        && data.status in ['new', 'qualified', 'contacted', 'closed', 'rejected']
        && data.updatedAt == request.time
        && data.chatHistory is list
        && data.qualifications is map
        // Strings size checks
        && (!('name' in data) || (data.name is string && data.name.size() <= 200))
        && (!('email' in data) || (data.email is string && data.email.size() <= 200))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('budget' in data) || (data.budget is number))
        && (!('summary' in data) || (data.summary is string && data.summary.size() <= 2000));
    }

    function isValidNotification(data) {
      let coreKeys = ['leadId', 'title', 'message', 'type', 'read', 'createdAt'];
      return data.keys().hasAll(coreKeys)
        && data.leadId is string && data.leadId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type in ['hot_lead', 'qualification_complete', 'system']
        && data.read is bool
        && data.createdAt == request.time;
    }

    match /leads/{leadId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Anyone can start a chat (create a lead)
      allow create: if isValidId(leadId) && isValidLead(incoming()) && incoming().createdAt == request.time;
      
      // Allow updates for guests so they can continue the chat and update their qualification
      // We protect against field tampering by checking immutable fields and valid schema
      allow update: if (
        isValidLead(incoming()) && 
        incoming().createdAt == existing().createdAt &&
        (
          isSignedIn() || // Agents have full update power via Dashboard
          (
            // Guest "Chat" updates: can only change their own profile info and history
            // In a real app, you'd use Auth or a session token, 
            // but here we validate the payload integrity.
            incoming().diff(existing()).affectedKeys().hasAny(['chatHistory', 'status', 'updatedAt', 'summary', 'qualifications', 'score', 'name', 'email', 'phone', 'location', 'budget', 'interests'])
          )
        )
      );

      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow list, get: if isSignedIn();
      allow create: if isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }
  }
}
